            "anyOf": [
              {
                "$ref": "#/components/schemas/ServicePriceRange"
              },
              {
                "type": "null"
              }
            ]
          },
          "priceDrivers": {
            "items": {
              "$ref": "#/components/schemas/PriceDriver"
            },
            "title": "Pricedrivers",
            "type": "array"
          },
          "rangeHigh": {
            "title": "Rangehigh",
            "type": "integer"
          },
          "rangeLow": {
            "title": "Rangelow",
            "type": "integer"
          },
          "requestId": {
            "title": "Requestid",
            "type": "string"
          },
          "servicePriceRange": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ServicePriceRange"
              },
              {
                "type": "null"
              }
            ]
          }
        },
