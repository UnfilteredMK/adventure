                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Budgettierranges"
          },
          "calibrationKey": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Calibrationkey"
          },
          "confidence": {
            "default": "low",
            "title": "Confidence",
            "type": "string"
          },
          "currency": {
            "default": "USD",
            "title": "Currency",
            "type": "string"
          },
          "deltaDirection": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Deltadirection"
          },
          "deltaPriceRange": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ServicePriceRange"
              },
              {
                "type": "null"
              }
            ]
          },
