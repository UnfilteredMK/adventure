{
  "buildCommand": "npm -w apps/widget run build",
  "installCommand": "node apps/widget/vercel-install.cjs",
  "framework": "nextjs",
  "outputDirectory": "apps/widget/.next",
  "functions": {
    "app/api/generate/route.ts": {
      "maxDuration": 300
    },
    "app/api/generate/try-on/route.ts": {
      "maxDuration": 300
    },
    "app/api/generate/scene/route.ts": {
      "maxDuration": 300
    },
    "app/api/generate/scene-placement/route.ts": {
      "maxDuration": 300
    },
    "app/api/leads/route.ts": {
      "maxDuration": 60
    },
    "app/api/leads/bill/route.ts": {
      "maxDuration": 60
    }
  }
}
