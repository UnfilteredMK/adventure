{
  "name": "adventure-widget",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20",
    "npm": ">=9"
  },
  "scripts": {
    "predev": "node ./scripts/ensure-next-runtime.cjs",
    "dev:raw": "set -a && . ../../env/.env.shared.local && set +a && BROWSERSLIST_IGNORE_OLD_DATA=1 node -r ./scripts/console-silence.cjs -r ./scripts/next-runtime-chunk-fix.cjs $(node -p \"require.resolve('next/dist/bin/next')\") dev -p 3001",
    "clean:next": "node -e \"const fs=require('fs');fs.rmSync('.next',{recursive:true,force:true});fs.rmSync('node_modules/.cache',{recursive:true,force:true});\"",
    "dev:clean": "npm run clean:next && npm run dev:raw",
    "dev:nocache": "npm run dev:clean",
    "dev": "npm run dev:raw",
    "build": "next build",
    "start": "set -a && . ../../env/.env.shared.local && set +a && next start",
    "lint": "next lint",
    "gen:types": "npm --prefix ../.. run supabase:gen:types",
    "db:update": "node ../../scripts/update-supabase.js",
    "sort:configs": "node ../../scripts/sort-configs.js"
  },
