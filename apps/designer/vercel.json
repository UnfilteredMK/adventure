{
  "framework": "nextjs",
  "installCommand": "node apps/designer/vercel-install.cjs",
  "buildCommand": "npm -w apps/designer run build",
  "outputDirectory": "apps/designer/.next",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Credentials",
          "value": "true"
        }
      ]
    }
  ]
} 