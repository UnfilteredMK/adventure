{
  "name": "adventure-designer",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.2.4",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.2.4"
  },
  "scripts": {
    "clean": "rm -rf .next",
    "dev": "set -a && . ../../env/.env.shared.local && set +a && next dev -p 3000",
    "dev:clean": "rm -rf .next && set -a && . ../../env/.env.shared.local && set +a && next dev -p 3000",
    "build": "NODE_ENV=production TSC_COMPILE_ON_ERROR=true next build",
    "build:clean": "rm -rf .next && set -a && . ../../env/.env.shared.local && set +a && NODE_ENV=production TSC_COMPILE_ON_ERROR=true next build",
    "start": "set -a && . ../../env/.env.shared.local && set +a && next start",
    "lint": "next lint",
    "generate:us-cities": "node scripts/generate-us-cities-20k.js",
    "generate:us-cities:all": "MIN_POP=0 ZIP_URL=https://download.geonames.org/export/dump/cities500.zip node scripts/generate-us-cities-20k.js",
    "shopify:dev": "shopify app dev",
    "generate:services": "node scripts/generate-service-images.js",
    "generate:samples": "node scripts/generate-sample-images.js",
    "backfill:service-summaries": "node scripts/backfill-service-summaries-to-supabase.js",
    "backfill:service-summaries:ai": "node scripts/backfill-service-summaries-ai.js",
    "backfill:instance-configs:v2": "node scripts/compact-instance-configs-to-v2.js",
    "update:service-summaries:prompt": "node scripts/update-service-summaries-from-prompt.js",
    "gen-types": "npm run gen-types:all",
    "gen-types:all": "npm --prefix ../.. run supabase:gen:types",
    "db:update": "node ../../scripts/update-supabase.js",
    "db:pull": "supabase db pull --schema public && cp supabase/migrations/*_schema.sql supabase/rls/policies.sql",
    "db:new": "supabase migration new",
    "db:push": "supabase db push",
    "sort:configs": "node ../../scripts/sort-configs.js",
    "backfill:refinement-library": "tsx scripts/backfill-refinement-library.ts"
  },
  "dependencies": {
    "@adventure/refinement-server": "file:../../shared/api/refinement-server",
    "@aws-sdk/client-s3": "^3.842.0",
    "@aws-sdk/s3-request-presigner": "^3.842.0",
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-aspect-ratio": "^1.0.3",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-collapsible": "^1.0.3",
    "@radix-ui/react-context-menu": "^2.1.5",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-hover-card": "^1.0.7",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-menubar": "^1.0.4",
    "@radix-ui/react-navigation-menu": "^1.1.4",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-toggle": "^1.0.3",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@stripe/stripe-js": "^2.2.0",
    "@supabase/auth-helpers-nextjs": "^0.10.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.53.0",
    "@shopify/shopify-api": "^11.0.0",
    "@shopify/app-bridge": "^3.7.8",
    "@shopify/app-bridge-react": "^3.7.8",
    "@vercel/analytics": "^1.5.0",
    "@vercel/blob": "^1.1.1",
    "autoprefixer": "^10.0.1",
    "axios": "^1.6.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.0.0",
    "cmdk": "^0.2.0",
    "critters": "^0.0.23",
    "csv-parser": "^3.2.0",
    "csv-writer": "^1.6.0",
    "date-fns": "^2.30.0",
    "dotenv": "^16.6.1",
    "embla-carousel-react": "^8.0.0-rc17",
    "framer-motion": "^10.18.0",
    "glob": "^10.3.10",
    "lodash": "^4.17.21",
    "lucide-react": "^0.525.0",
    "next": "^14.2.5",
    "next-themes": "^0.2.1",
    "openai": "^5.10.2",
    "postcss": "^8.4.31",
    "react": "^18",
    "react-day-picker": "^8.9.1",
    "react-dom": "^18",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.60.0",
    "react-icons": "^5.5.0",
    "react-xarrows": "^2.0.2",
    "replicate": "^1.0.1",
    "resend": "^4.7.0",
    "sonner": "^1.2.4",
    "stripe": "^14.25.0",
    "tailwind-merge": "^2.6.0",
    "tailwind-scrollbar": "^3.1.0",
    "tailwindcss": "^3.3.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^13.0.0",
    "vaul": "^0.8.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.10",
    "@types/glob": "^8.1.0",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.19.4",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "@typescript-eslint/parser": "^8.36.0",
    "cssnano": "^7.0.7",
    "eslint": "^8.0.0",
    "eslint-config-next": "14.2.5",
    "eslint-plugin-perfectionist": "^4.15.0",
    "jscodeshift": "^0.15.2",
    "kill-port": "^2.0.1",
    "supabase": "^2.30.4",
    "tsx": "^4.19.2",
    "typescript": "5.8.3"
  }
}
